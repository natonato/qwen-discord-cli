# Discord Bot Token
# Get this from: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Allowed Channel IDs (comma-separated, at least one required)
# Right-click a channel -> Copy ID (Developer Mode required)
ALLOWED_CHANNEL_IDS=channel_id_1,channel_id_2

# Allowed User IDs (comma-separated, empty = allow all users in the channel)
# Right-click a user -> Copy ID (Developer Mode required)
ALLOWED_USER_IDS=user_id_1,user_id_2

# Qwen CLI Approval Mode
# Options: yolo (auto-approve all), auto_edit (auto-approve edits), default (manual approval)
QWEN_APPROVAL_MODE=yolo

# Qwen Working Directory (optional, defaults to current directory)
# QWEN_WORKING_DIR=/path/to/your/project

# Log Level (optional, defaults to info)
# Options: debug, info, warn, error
LOG_LEVEL=info
